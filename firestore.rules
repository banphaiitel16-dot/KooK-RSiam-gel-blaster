rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.3 Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // We allow blanket reads for settings and products.
    // However, as requested in Firebase skill, we should not do blanket reads blindly unless the app is public data.
    // Products are public, Settings are public, Orders are private (only admin).
    // Admin check: No authentication is strictly defined yet (no users collection etc). But let's assume we can set an admin via token verification or basically the rule needs to be tested. The user has no Real auth setup... wait.
    // The previous app state had "userPasswords" in localStorage. That means NO REAL FIREBASE AUTH!
    // But since `set_up_firebase` just created a Firebase project WITH auth, I MUST use Firebase Auth!
    // I should create an initial setup for users to login as admin.
    
    match /settings/{settingId} {
      allow get: if isValidId(settingId);
      allow list: if true;
      allow write: if request.auth != null; // only logged-in users can write (we consider them admins for now)
    }

    match /products/{productId} {
      allow get: if isValidId(productId);
      allow list: if true;
      allow write: if request.auth != null; // only logged in users (admins) can write products
    }

    match /orders/{orderId} {
      allow get: if isValidId(orderId) && request.auth != null;
      allow list: if request.auth != null;
      allow write: if request.auth != null && isValidId(orderId);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /users/{userId} {
      allow get: if request.auth != null;
      allow list: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
